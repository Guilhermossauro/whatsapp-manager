# WhatsApp Manager - Configuração de Ambiente

# ============ SERVIDOR ============
NODE_ENV=development
PORT=3001

# ============ BANCO DE DADOS ============
DATABASE_PATH=./whatsapp_manager.db

# ============ WHATSAPP ============
# true = Modo Simulado (sem WhatsApp real)
# false = Integração real com WhatsApp Web.js
MOCK_MODE=true

# Opcional: Caminho do Chrome/Chromium (auto-detectado se vazio)
CHROME_PATH=

# ============ LOGGING ============
# debug | info | warn | error
LOG_LEVEL=info

# ============ WORKERS ============
# Intervalo de processamento da fila (milissegundos)
WORKER_INTERVAL=5000

# Limite de mensagens processadas por ciclo
WORKER_BATCH_SIZE=10
